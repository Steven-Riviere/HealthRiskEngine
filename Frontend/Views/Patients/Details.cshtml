@model Frontend.Models.PatientViewModel
@using System.ComponentModel.DataAnnotations
@functions {
    string GetEnumDisplayName(Enum enumValue)
    {
        var display = enumValue.GetType()
                               .GetField(enumValue.ToString())
                               ?.GetCustomAttributes(typeof(DisplayAttribute), false)
                               .Cast<DisplayAttribute>()
                               .FirstOrDefault();
        return display?.Name ?? enumValue.ToString();
    }
}
@{
    ViewData["Title"] = "Détails du patient";
}

<main class="container my-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4 rounded-top-0">
                <div class="p-2 mb-2 bg-primary text-white rounded-top">
                    <h5 class="mb-0"><i class="fa-solid fa-user me-1"></i> Informations patient(e)</h5>
                </div>
                <div class="card-body">
                    <h4 class="card-title text-center">@Model.FirstName @Model.LastName</h4>
                    <p class="mb-2">
                        <i class="fa-solid fa-birthday-cake me-1"></i>
                        <strong>Date de naissance :</strong> @Model.DateOfBirth.ToShortDateString() (@Model.Age ans)
                    </p>
                    <p class="mb-2">
                        <i class="fa-solid fa-venus-mars me-1"></i>
                        <strong>Genre :</strong> @GetEnumDisplayName(Model.Gender)
                    </p>
                    @if (!string.IsNullOrEmpty(Model.City))
                    {
                        <p class="mb-2">
                            <i class="fa-solid fa-location-dot me-1"></i>
                            <strong>Ville :</strong> @Model.City
                        </p>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <p class="mb-2">
                            <i class="fa-solid fa-phone me-1"></i>
                            <strong>Téléphone :</strong> @Model.Phone
                        </p>
                    }
                    <div class="mt-4 d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1 btn-hover">
                            <i class="fa-solid fa-arrow-left me-1"></i> Retour
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                            <i class="fa-solid fa-pen-to-square me-1"></i> Modifier patient
                        </a>
                    </div>

					@await Html.PartialAsync("_RiskFactors")
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="p-2 mb-2 bg-primary text-white rounded-top">
                    <h5 class="mb-0"><i class="fa-solid fa-notes-medical me-1"></i> Analyse santé</h5>
                </div>
                <div class="card-body rounded-top-0">
                    @if (Model.DiabetesRisk != null)
                    {
                        <div class="text-center mb-4">
                            <div class="risk-indicator">

                                <div class="card @Model.DiabetesRisk.BgClass p-3">
                                    <h5 class="mb-0">
                                        <i class="@Model.DiabetesRisk.IconClass me-2"></i>
                                        @Model.DiabetesRisk.DisplayName
                                    </h5>
                                </div>
                            </div>
                        </div>

                    }
                    @if (Model.CancersRisk != null)
                    {
                        <div class="text-center mb-4">
                            <div class="risk-indicator">

                                <div class="card @Model.CancersRisk.BgClass p-3">
                                    <h5 class="mb-0">
                                        <i class="@Model.CancersRisk.IconClass me-2"></i>
                                        @Model.CancersRisk.DisplayName
                                    </h5>
                                </div>
                            </div>
                        </div>

                    }

                </div>
            </div>


            <div class="card shadow-sm mb-4">
                <div class="d-flex justify-content-between align-items-center p-2 mb-2 bg-primary text-white rounded-top">
                    <h5 class="mb-0"><i class="fa-solid fa-clipboard-list me-1"></i> Notes médicales</h5>
                    <a href="@Url.Action("Create", "Notes", new { patientId = Model.Id })" class="btn btn-sm"
                       style="background-color: white; color: black; border: 1px solid #000;">
                        <i class="fa-solid fa-plus"></i> Nouvelle note
                    </a>
                </div>
                <div class="card-body rounded-top-0">
                    @if (Model.Notes != null && Model.Notes.Any())
                    {
                        @foreach (var note in Model.Notes)
                        {
                            <div class="timeline-item mb-3">
                                <div class="timeline-date mb-1">
                                    <span class="badge bg-secondary">
                                        <i class="fa-regular fa-calendar me-1"></i>
                                        @note.DateAppointment.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </div>
                                <div class="timeline-content">
                                    <div class="card shadow-sm">
                                        <div class="card-body">
                                            @Html.Raw(note.Notes.Replace("\n", "<br/>"))
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Aucune note pour le moment.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
