@{
    ViewData["Title"] = "Connexion";
}
<main class="container" style="max-width: 600px; margin: 40px auto;">

    <div class="card shadow-sm mx-auto">
        <div class="card-body">
            <h4 class="card-title mb-3 text-center">Connexion</h4>

            <form asp-action="Login" method="post">
                <p class="text-muted mb-3"><span class="text-danger">*</span> Champs obligatoires</p>
                <div class="form-group mb-3">
                    <label for="email" class="form-label">Mail <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="email" name="email" required />
                </div>

                <div class="form-group mb-3">
                    <label for="password" class="form-label">Mot de passe <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" id="password" name="password" required />
                </div>

                <button type="submit" class="btn btn-success flex-grow-1 btn-hover w-100">
                    <i class="fa-solid fa-right-to-bracket me-1"></i> Se connecter
                </button>
            </form>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-danger mt-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }
        </div>
    </div>
</main>
